# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Secrets — never commit the real .env ─────────────────────────────────────
.env

# ── Data (processed outputs and model artefacts are derived; raw may be large) 
data/processed/*
!data/processed/.gitkeep
data/raw/*
!data/raw/.gitkeep

# ── MLflow ────────────────────────────────────────────────────────────────────
mlruns/
mlflow-artifacts/

# ── Saved models / job artefacts ─────────────────────────────────────────────
# Ignore everything under artifacts/ by default (contents, not the dir itself)
# so we can selectively re-include the benchmark report below.
artifacts/*
outputs/
*.pkl
*.joblib

# Keep the benchmark report (markdown + csv) but not charts or saved models
!artifacts/reports/
artifacts/reports/*
!artifacts/reports/*.md
!artifacts/reports/*.csv

# ── Spark ─────────────────────────────────────────────────────────────────────
spark-warehouse/
metastore_db/
derby.log

# ── Kafka producer ────────────────────────────────────────────────────────────
# Checkpoint file (runtime state, not source code)
artifacts/producer_checkpoint.json
# Producer run logs (if redirected to a file)
producer_*.log

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Test / lint caches ────────────────────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
