# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Secrets — never commit the real .env ─────────────────────────────────────
.env

# ── Data (processed outputs and model artefacts are derived; raw may be large) 
data/processed/*
!data/processed/.gitkeep
data/raw/*
!data/raw/.gitkeep

# ── MLflow ────────────────────────────────────────────────────────────────────
mlruns/
mlflow-artifacts/

# ── Saved models / job artefacts ─────────────────────────────────────────────
artifacts/
outputs/
*.pkl
*.joblib

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Test / lint caches ────────────────────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
