# =============================================================================
# churnops — environment variables / secrets
# Copy this file to .env and fill in real values.  NEVER commit .env.
# Non-secret config (topic names, ports, paths) lives in configs/app.yaml.
# =============================================================================

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=churnops
POSTGRES_PASSWORD=churnops_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:3000

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Airflow ───────────────────────────────────────────────────────────────────
# Used by the Airflow init container and webserver; not consumed by churnops lib
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW__CORE__FERNET_KEY=<generate-with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://churnops:churnops_secret@postgres:5432/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__WEBSERVER__SECRET_KEY=<replace-with-random-string>
