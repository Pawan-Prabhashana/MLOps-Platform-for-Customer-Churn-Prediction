# =============================================================================
# churnops — environment variables / secrets
# Copy this file to .env and fill in real values.  NEVER commit .env.
# Non-secret config (topic names, ports, paths) lives in configs/app.yaml.
# =============================================================================

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=churnops
POSTGRES_PASSWORD=churnops_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Monitoring store (drift / performance / predictions / alerts) ────────────
# Plain Postgres connection string used by src/churnops/monitoring/. Leave
# blank to default to the local docker `churnops` database (postgres_* above).
# To write to Supabase instead: Supabase dashboard -> Project -> Settings ->
# Database -> Connection string (URI, "Session pooler" or direct connection),
# paste it here. Same code, zero changes — Supabase is plain Postgres.
#   DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=

# Optional — only needed if you use the supabase-py client directly instead of
# SQLAlchemy/psycopg (the monitoring layer here uses plain SQLAlchemy, so
# these are unused unless you add supabase-py yourself).
SUPABASE_URL=
SUPABASE_KEY=

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:3000

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Airflow ───────────────────────────────────────────────────────────────────
# Used by the Airflow init container and webserver; not consumed by churnops lib
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW__CORE__FERNET_KEY=<generate-with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://churnops:churnops_secret@postgres:5432/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__WEBSERVER__SECRET_KEY=<replace-with-random-string>
